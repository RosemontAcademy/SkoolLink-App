{
  "name": "skoollink-app",
  "productName": "SkoolLink",
  "version": "1.1.0",
  "description": "SkoolLink desktop shell — Rosemont Academy admin console",
  "main": "src/main.js",
  "author": "Rosemont Academy",
  "license": "UNLICENSED",
  "repository": "github:RosemontAcademy/SkoolLink-App",
  "scripts": {
    "start": "electron .",
    "icons": "node scripts/make-ico.mjs",
    "dist": "electron-builder --win --publish never",
    "dist:mac": "electron-builder --mac --publish never",
    "dist:mac:publish": "electron-builder --mac --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^38.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "kr.rosemont.skoollink",
    "productName": "SkoolLink",
    "artifactName": "SkoolLink-Setup-${version}.${ext}",
    "protocols": [
      {
        "name": "SkoolLink",
        "schemes": [
          "skoollink"
        ]
      }
    ],
    "files": [
      "src/**/*",
      "assets/**/*",
      "!assets/ico/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "shortcutName": "SkoolLink",
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": "universal"
        },
        {
          "target": "zip",
          "arch": "universal"
        }
      ],
      "category": "public.app-category.education",
      "icon": "build/icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true,
      "artifactName": "SkoolLink-${version}-${arch}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "RosemontAcademy",
      "repo": "SkoolLink-App"
    }
  }
}
